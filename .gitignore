# ─── Build output ───────────────────────────────────────────────────────────
dist/
.astro/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Cloudflare Wrangler (local cache, state, secrets) ────────────────────────
.wrangler/
.dev.vars*
!.dev.vars.example

# ─── Environment & secrets ────────────────────────────────────────────────────
# Never commit API keys or local overrides (Vite/Astro + Wrangler)
.env*
!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── TypeScript / tooling caches ──────────────────────────────────────────────
*.tsbuildinfo
.eslintcache
.turbo/

# ─── Test & coverage (if added later) ─────────────────────────────────────────
coverage/
test-results/

# ─── Deploy platform local config ─────────────────────────────────────────────
.vercel/
.netlify/

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Editor / IDE (local only — .vscode/ is committed for shared settings) ───
.idea/
*.code-workspace
*.swp
*~

# ─── AI assistant local settings (not shared project docs like CLAUDE.md) ─────
.claude/
.cursor/

# ─── Sensitive key material ───────────────────────────────────────────────────
*.pem
*.key
credentials.json
secrets.json


---
/**
 * index.astro — Single-page entry point (light theme)
 */
import MainLayout      from '../layouts/MainLayout.astro';
import PromptInput     from '../components/PromptInput.astro';
import Controls        from '../components/Controls.astro';
import ModelCard       from '../components/ModelCard.astro';
import VolumeEstimator from '../components/VolumeEstimator.astro';
---

<MainLayout
  title="TokenCalc AI — Prompt Token & Cost Calculator"
  description="Calculate exact token counts and projected API costs for GPT-5, Claude 4, Gemini 3, and more. 100% client-side, no API key needed."
>

  <!-- ── Top Navigation ─────────────────────────────────────────────── -->
  <nav class="fixed top-0 inset-x-0 z-50 h-[64px]
              bg-white/90 backdrop-blur-xl nav-shadow">
    <div class="max-w-7xl mx-auto h-full px-4 md:px-8
                flex items-center justify-between gap-6">

      <!-- Brand -->
      <a href="/" class="flex items-center gap-2 shrink-0 group">
        <div class="w-7 h-7 rounded-lg flex items-center justify-center
                    shadow-sm border border-[#dee3e6]"
             style="background:#00687a">
          <span class="material-symbols-outlined text-[16px] text-white"
                style="font-variation-settings:'FILL' 1">bolt</span>
        </div>
        <span class="font-headline font-bold text-[17px] tracking-tight"
              style="color:#171d1e">
          TokenCalc <span style="color:#00687a">AI</span>
        </span>
      </a>

      <!-- Nav links (desktop) -->
      <div class="hidden md:flex items-center gap-7">
        <a href="#workspace"
           class="nav-link-active font-mono text-[11px] uppercase tracking-widest
                  hover:opacity-80 transition-opacity">
          Models
        </a>
        <a href="#volume"
           class="font-mono text-[11px] uppercase tracking-widest transition-colors"
           style="color:#6d797d; hover:color:#171d1e">
          Volume
        </a>
        <a href="https://openai.com/api/pricing" target="_blank" rel="noopener"
           class="font-mono text-[11px] uppercase tracking-widest flex items-center gap-1
                  transition-colors"
           style="color:#6d797d">
          Pricing
          <span class="material-symbols-outlined text-[13px]">open_in_new</span>
        </a>
      </div>

      <!-- Trailing actions -->
      <div class="flex items-center gap-2">
        <!-- Copy Stats button -->
        <button
          id="copyStatsBtn"
          type="button"
          aria-label="Copy calculation summary to clipboard"
          class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg cursor-pointer
                 border border-[#dee3e6] bg-white
                 hover:border-[#00687a]/50 hover:shadow-sm
                 active:scale-95 transition-all duration-150"
          style="color:#3d494c">
          <span class="material-symbols-outlined text-[17px]">content_copy</span>
          <span class="font-mono text-[11px] uppercase tracking-widest hidden sm:inline">Copy Stats</span>
        </button>

        <!-- Source icon -->
        <a href="https://github.com" target="_blank" rel="noopener"
           aria-label="View source on GitHub"
           class="w-9 h-9 flex items-center justify-center rounded-lg
                  border border-transparent hover:border-[#dee3e6] hover:bg-[#eff4f7]
                  transition-all duration-150"
           style="color:#6d797d">
          <span class="material-symbols-outlined text-[20px]">code</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- ── Page body ──────────────────────────────────────────────────── -->
  <div class="flex flex-col flex-grow pt-[64px]">

    <!-- ── Hero / Workspace Section ───────────────────────────────── -->
    <section id="workspace"
             class="border-b py-10 px-4 md:px-8"
             style="background:#f5fafc; border-color:#dee3e6">
      <div class="max-w-7xl mx-auto flex flex-col gap-6">

        <!-- Section header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
          <div>
            <h1 class="font-headline font-bold text-3xl md:text-4xl tracking-tight leading-tight mb-2"
                style="color:#171d1e">
              Prompt Workspace
            </h1>
            <p class="font-mono text-sm" style="color:#6d797d">
              Input text to calculate exact token usage and projected costs across all models.
            </p>
          </div>

          <!-- Pricing badge -->
          <div class="flex items-center gap-2 px-3 py-1.5 rounded-full border shrink-0"
               style="background:#eff4f7; border-color:#dee3e6">
            <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#00687a"></span>
            <span class="font-mono text-[11px]" style="color:#6d797d">May 2026 Pricing</span>
          </div>
        </div>

        <!-- Prompt textarea -->
        <PromptInput />

        <!-- Slider + calls controls -->
        <Controls />
      </div>
    </section>

    <!-- ── Projections Section ─────────────────────────────────────── -->
    <section class="py-10 px-4 md:px-8 flex-grow"
             style="background:#eff4f7">
      <div class="max-w-7xl mx-auto flex flex-col gap-8">

        <!-- Inference cost projections header -->
        <div class="flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center border shrink-0"
                style="background:#ffffff; border-color:#dee3e6">
            <span class="material-symbols-outlined text-[18px]" style="color:#00687a">data_usage</span>
          </span>
          <h2 class="font-headline font-semibold text-2xl md:text-[26px] tracking-tight"
              style="color:#171d1e">
            Inference Cost Projections
          </h2>
        </div>

        <!-- Model cards grid (populated by JS) -->
        <ModelCard />

        <!-- Volume / bar chart -->
        <div id="volume">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-8 h-8 rounded-lg flex items-center justify-center border shrink-0"
                  style="background:#ffffff; border-color:#dee3e6">
              <span class="material-symbols-outlined text-[18px]" style="color:#8c5000">bar_chart</span>
            </span>
            <h2 class="font-headline font-semibold text-2xl md:text-[26px] tracking-tight"
                style="color:#171d1e">
              Monthly Volume Estimator
            </h2>
          </div>
          <VolumeEstimator />
        </div>

      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────────────────── -->
    <footer class="border-t px-4 md:px-8 py-5"
            style="background:#f5fafc; border-color:#dee3e6">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center
                  justify-between gap-3 font-mono text-[11px]"
           style="color:#6d797d">
        <p>
          Pricing last updated <span style="color:#3d494c">May 2026</span> ·
          For estimation only · Prices may vary
        </p>
        <p class="flex items-center gap-1">
          Built with
          <span style="color:#00687a" class="mx-0.5">Astro</span> +
          <span style="color:#0284c7" class="mx-0.5">Tailwind</span> +
          <span style="color:#8c5000" class="mx-0.5">tiktoken-lite</span>
        </p>
      </div>
    </footer>
  </div>

</MainLayout>

<!-- ── Client-side calculator ─────────────────────────────────────────────── -->
<script>
  import { init } from '../scripts/calculator.js';
  init();
</script>

---
// Nav.astro
const isHome = Astro.url.pathname === '/';
---
<nav class="fixed top-0 inset-x-0 z-50 h-[72px] sm:h-[80px]
            transition-all border-b"
     style="background:var(--nav-bg); border-color:var(--s4); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);">
  <div class="max-w-7xl mx-auto h-full px-4 sm:px-6 md:px-8
              flex items-center justify-between gap-4">

    <!-- Left: Logo & Brand -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group">
      <img
        src="/favicon-96x96.png"
        alt="TokenCalc AI"
        class="w-10 h-10 sm:w-12 sm:h-12 object-contain shrink-0"
        onerror="this.onerror=null; this.src='/favicon.png'; this.onerror=()=>this.src='/logo.png';"
      />
      <span class="font-bold text-[20px] sm:text-[24px] tracking-tighter"
            style="color:var(--t1)">
        TokenCalc <span style="color:var(--primary)">AI</span>
      </span>
    </a>

    <!-- Center: Nav links (desktop only) -->
    <div class="hidden md:flex items-center gap-8 lg:gap-10">
      <a href="/#workspace"
         class="nav-link-active font-mono text-[11px] uppercase tracking-widest
                hover:opacity-80 transition-opacity">
        Models
      </a>
      <a href="/#volume"
         class="font-mono text-[11px] uppercase tracking-widest transition-colors"
         style="color:var(--t3)"
         onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--t3)'">
        Volume
      </a>
      <a href="/about"
         class="font-mono text-[11px] uppercase tracking-widest transition-colors"
         style="color:var(--t3)"
         onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--t3)'">
        About
      </a>
      <a href="/contact"
         class="font-mono text-[11px] uppercase tracking-widest transition-colors"
         style="color:var(--t3)"
         onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--t3)'">
        Contact
      </a>
      <a href="https://openai.com/api/pricing" target="_blank" rel="noopener"
         class="font-mono text-[11px] uppercase tracking-widest flex items-center gap-1 transition-colors"
         style="color:var(--t3)"
         onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--t3)'">
        Pricing
        <span class="material-symbols-outlined text-[13px]">open_in_new</span>
      </a>
    </div>

    <!-- Right: Actions -->
    <div class="flex items-center gap-1.5 sm:gap-2">
      {isHome && (
        <!-- Copy Stats button -->
        <button
          id="copyStatsBtn"
          type="button"
          aria-label="Copy calculation summary to clipboard"
          class="flex items-center gap-1.5 px-3 sm:px-4 py-2 sm:py-2.5 rounded-lg cursor-pointer
                 border transition-all duration-150 active:scale-95"
          style="color:var(--t2); border-color:var(--s4); background:var(--s1)">
          <span class="material-symbols-outlined text-[19px] sm:text-[18px]">content_copy</span>
          <span class="font-mono text-[11px] uppercase tracking-widest hidden sm:inline">Copy Stats</span>
        </button>
      )}

      <!-- Dark Mode Toggle -->
      <button
        id="themeToggle"
        type="button"
        aria-label="Toggle dark mode"
        class="w-10 h-10 sm:w-11 sm:h-11 flex items-center justify-center rounded-lg
               border transition-all duration-150"
        style="color:var(--t3); border-color:var(--s4); background:var(--s1)">
        <!-- Moon: shown in light mode -->
        <span id="icon-moon" class="material-symbols-outlined text-[21px]">dark_mode</span>
        <!-- Sun: shown in dark mode -->
        <span id="icon-sun" class="material-symbols-outlined text-[21px]">light_mode</span>
      </button>

      <!-- Source icon -->
      <a href="https://github.com/ThatKJ/tokencalc" target="_blank" rel="noopener"
         aria-label="View source on GitHub"
         class="w-10 h-10 sm:w-11 sm:h-11 flex items-center justify-center rounded-lg
                border border-transparent transition-all duration-150"
         style="color:var(--t3)"
         onmouseover="this.style.borderColor='var(--s4)'; this.style.background='var(--s2)'"
         onmouseout="this.style.borderColor='transparent'; this.style.background='transparent'">
        <span class="material-symbols-outlined text-[22px]">code</span>
      </a>
    </div>
  </div>
</nav>

<script>
  // Dark mode toggle
  const btn = document.getElementById('themeToggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (_) {}
    });
  }
</script>

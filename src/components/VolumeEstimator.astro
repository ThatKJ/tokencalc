---
/**
 * VolumeEstimator.astro — Monthly volume estimator, theme-aware
 */
---

<div class="card overflow-hidden">
  <!-- Bar chart (JS-rendered) -->
  <div id="chartContainer" class="flex flex-col py-2 gap-0">
    <div class="text-center py-10 font-mono text-xs sm:text-sm" style="color:var(--s5)">
      No data to visualise yet
    </div>
  </div>

  <!-- Footer note -->
  <div class="border-t px-4 sm:px-5 py-3 transition-colors" style="border-color:var(--s4)">
    <p class="text-caption" style="color:var(--t3)">
      Pricing last updated June 2026 · For estimation purposes only · All figures in USD
    </p>
  </div>
</div>

---
/**
 * Controls.astro — light theme
 */
---

<div class="card p-5 flex flex-col md:flex-row gap-6 md:items-center">

  <!-- Output Multiplier Slider -->
  <div class="flex-1 flex flex-col gap-3">
    <div class="flex items-center justify-between">
      <label
        for="outputMultiplier"
        class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.1em]"
        style="color:#3d494c">
        <span class="material-symbols-outlined text-[17px]" style="color:#6d797d">output</span>
        Output Multiplier
      </label>
      <span id="multiplierValue"
            class="font-mono text-sm font-bold px-2.5 py-0.5 rounded-full border"
            style="color:#00687a; background:rgba(0,104,122,0.08); border-color:rgba(0,104,122,0.2)">
        2.0x
      </span>
    </div>

    <input
      id="outputMultiplier"
      type="range"
      min="0.5"
      max="4.0"
      step="0.1"
      value="2.0"
      aria-label="Output token multiplier"
    />

    <p class="text-[11px] font-mono" style="color:#6d797d">
      Estimated output tokens relative to input. Default: 2.0×
    </p>
  </div>

  <!-- Divider -->
  <div class="hidden md:block w-px self-stretch" style="background:#dee3e6"></div>
  <div class="md:hidden h-px w-full" style="background:#dee3e6"></div>

  <!-- Daily Calls Volume -->
  <div class="flex-1 flex flex-col gap-3">
    <label
      for="dailyCalls"
      class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.1em]"
      style="color:#3d494c">
      <span class="material-symbols-outlined text-[17px]" style="color:#6d797d">all_inclusive</span>
      Daily Calls Volume
    </label>

    <div class="relative">
      <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
        <span class="material-symbols-outlined text-[17px]" style="color:#6d797d">tag</span>
      </span>
      <input
        id="dailyCalls"
        type="number"
        min="1"
        value="1000"
        aria-label="Number of API calls per day"
        class="w-full rounded-lg pl-9 pr-4 py-2.5 font-mono text-sm
               border transition-colors duration-200"
        style="background:#ffffff; border-color:#bcc9cd; color:#171d1e"
      />
    </div>

    <p class="text-[11px] font-mono" style="color:#6d797d">
      Used for monthly projection charts. (30-day month)
    </p>
  </div>
</div>
